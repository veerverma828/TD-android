{
  "expo": {
    "name": "TD-android",
    "slug": "TD-android",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "tdandroid",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.tdandroid.app"
    },
    "newArchEnabled": false,
    "android": {
      "package": "com.tdandroid.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": ["REQUEST_INSTALL_PACKAGES"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0d12",
          "image": "./assets/images/icon.png",
          "imageWidth": 160
        }
      ],
      "expo-secure-store",
      "expo-dev-client",
      "expo-notifications",
      "./plugins/withAndroidTVBanner.js",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "buildNumber": 0,
      "githubRepo": "veerverma828/TD-android"
    }
  }
}
