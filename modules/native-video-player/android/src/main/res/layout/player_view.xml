<?xml version="1.0" encoding="utf-8"?>
<!--
  surface_type="surface_view" (the PlayerView default) — direct hardware compositor
  overlay, not routed through the app's GL view hierarchy like TextureView is. Needed
  for smooth playback (no extra per-frame composite/copy) and for window.colorMode=
  COLOR_MODE_HDR (see PlayerActivity.applyHdrColorMode) to actually reach the display;
  TextureView content is composited as a normal app-owned GL texture, so HDR/Dolby
  Vision streams render dark/washed out on many OEM GPU drivers even with the HDR
  color mode set. Used for normal (non-PiP) playback only — see player_view_pip.xml
  for the PiP-mode surface, which trades this back for TextureView's PiP-transition
  compatibility.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="surface_view" />
